<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{TITLE}}</title>
  <style>
    :root {
      color-scheme: light dark;
      --fg: #1a1a1a;
      --bg: #fafafa;
      --muted: #666;
      --card-bg: #fff;
      --card-border: #e2e2e2;
      --accent: #2b6cb0;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --fg: #e8e8e8;
        --bg: #121212;
        --muted: #9a9a9a;
        --card-bg: #1c1c1c;
        --card-border: #2a2a2a;
        --accent: #80b3ff;
      }
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--fg);
      background: var(--bg);
      line-height: 1.5;
    }
    main {
      max-width: 720px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    h1 {
      font-size: 2rem;
      margin: 0 0 2rem;
    }
    ul.presentations {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 1rem;
    }
    .card a {
      display: block;
      padding: 1.25rem 1.5rem;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 8px;
      color: inherit;
      text-decoration: none;
      transition: border-color 120ms ease, transform 120ms ease;
    }
    .card a:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
    }
    .card h2 {
      margin: 0 0 0.25rem;
      font-size: 1.15rem;
    }
    .card p {
      margin: 0 0 0.5rem;
      color: var(--muted);
    }
    .card time {
      font-size: 0.85rem;
      color: var(--muted);
    }
    footer {
      margin-top: 3rem;
      font-size: 0.8rem;
      color: var(--muted);
    }
    footer a {
      color: var(--muted);
      text-decoration: underline;
    }
    footer a:hover {
      color: var(--accent);
    }
  </style>
</head>
<body>
  <main>
    <h1>{{TITLE}}</h1>
    <ul class="presentations">
      {{PRESENTATIONS}}
    </ul>
    <footer>
      <a href="https://github.com/hay-kot/presentations">Source on GitHub</a>
      &middot; Generated {{GENERATED_AT}}
    </footer>
  </main>
</body>
</html>
